# Backend port (default: 3001)
PORT=3001

# Optional: override the WebSocket URL the client connects to.
# Leave unset to use the Vite proxy (recommended for local dev).
# Set this in production if the backend is on a different host.
# VITE_WS_URL=ws://your-backend-host:3001/ws

# Allowed origin for WebSocket connections (production only).
# Localhost is always allowed. Set this to your frontend's public URL
# when the client and backend are on different hosts.
# ALLOWED_ORIGIN=https://servercity.example.com
